        <!-- cross-layer edges -->
        <mxCell id="cl1" edge="1" parent="1" source="9" style="dashed=1;strokeColor=#9673a6;fontColor=#9673a6;fontStyle=2;endArrow=block;endFill=1;" target="11" value="POST aidlc-governance-event/v1&#xa;WXO_API_KEY → IAM token exchange">
