        </mxCell>

        <!-- fallback email tool — highlighted differently -->
        <mxCell id="t5" parent="10" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#f0a30a;fontSize=11;fontStyle=1;" value="Tool: send_outlook_email&#xa;FALLBACK ONLY — fires when&#xa;OpenPages returns failure" vertex="1">
          <mxGeometry height="65" width="175" x="760" y="55" as="geometry" />
        </mxCell>

        <!-- routing decision diamond -->
        <mxCell id="r1" parent="10" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="OpenPages&#xa;healthy?" vertex="1">
