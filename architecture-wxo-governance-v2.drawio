        <mxCell id="e_ok" edge="1" parent="10" source="r1" target="t4" value="" style="strokeColor=#107C10;fontColor=#107C10;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="580" y="160"/><mxPoint x="580" y="228"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="e_ok_lbl" parent="10" style="text;html=1;align=center;verticalAlign=middle;resizable=0;fontSize=10;fontColor=#107C10;" value="✓ created/updated&#xa;→ native email via OpenPages WF" vertex="1">
          <mxGeometry x="430" y="148" width="170" height="30" as="geometry" />
        </mxCell>
        <mxCell id="e_fail" edge="1" parent="10" source="r1" target="t5" value="✗ failed" style="strokeColor=#f0a30a;fontColor=#f0a30a;fontStyle=1;"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ═══ LAYER 3: OpenPages ═══ -->
        <mxCell id="op_swim" parent="1" style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#107C10;fontStyle=1;fontSize=13;" value="Layer 3 — OpenPages (authoritative GRC record)" vertex="1">
          <mxGeometry height="220" width="960" x="40" y="890" as="geometry" />
        </mxCell>

        <mxCell id="op1" parent="op_swim" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#107C10;strokeColor=#0E5A0E;fontColor=#ffffff;fontSize=11;" value="OpenPages&#xa;Issue Record&#xa;per rule violation&#xa;(dedup: repo+pr+rule)" vertex="1">
          <mxGeometry height="100" width="160" x="80" y="70" as="geometry" />
        </mxCell>
        <mxCell id="op2" parent="op_swim" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#107C10;strokeColor=#0E5A0E;fontColor=#ffffff;fontSize=11;" value="OpenPages&#xa;Metrics Record&#xa;pass/fail trends&#xa;by repo/actor/rule" vertex="1">
          <mxGeometry height="100" width="160" x="400" y="70" as="geometry" />
        </mxCell>
        <mxCell id="op3" parent="op_swim" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#107C10;fontSize=11;" value="OpenPages Workflow Engine&#xa;fires native email on Issue Open/transition&#xa;(audited · throttled · retried by GRC)" vertex="1">
          <mxGeometry height="60" width="210" x="700" y="80" as="geometry" />
        </mxCell>

        <!-- ═══ External outputs ═══ -->
        <mxCell id="out1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0078D4;strokeColor=#001E4E;fontColor=#ffffff;fontSize=11;" value="📧 Outlook Email&#xa;PRIMARY: OpenPages WF engine&#xa;(audited, retried, throttled)" vertex="1">
          <mxGeometry height="70" width="190" x="740" y="1160" as="geometry" />
        </mxCell>
        <mxCell id="out2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#f0a30a;fontColor=#000000;fontSize=11;fontStyle=1;" value="📧 Outlook Email&#xa;FALLBACK: wxO Graph API tool&#xa;(fires only if OpenPages is down)" vertex="1">
          <mxGeometry height="70" width="200" x="40" y="870" as="geometry" />
