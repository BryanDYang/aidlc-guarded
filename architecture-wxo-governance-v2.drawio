        <mxCell id="cl5" edge="1" parent="1" source="op1" target="op3" value="Issue created/opened" style="strokeColor=#107C10;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cl6" edge="1" parent="1" source="t5" target="out2" value="fallback only" style="strokeColor=#f0a30a;fontStyle=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══ Annotation boxes ═══ -->
        <mxCell id="ann1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffacd;strokeColor=#d6b656;align=left;spacingLeft=6;fontSize=10;verticalAlign=top;" value="Payload → OpenPages field mapping:&#xa;• violations[].rule  →  Control ID / Issue Type&#xa;• violations[].detail  →  Issue Description&#xa;• violations[].severity  →  Risk Rating&#xa;• actor  →  Reported By&#xa;• pr_url  →  Evidence URL&#xa;• repo + project  →  Business Entity&#xa;• timestamp  →  Created Date&#xa;• verdict=FAIL  →  Status = Open&#xa;• verdict=PASS  →  Status = Closed (auto)" vertex="1">
          <mxGeometry height="150" width="280" x="330" y="1160" as="geometry" />
        </mxCell>
        <mxCell id="ann2" parent="1" style="whiteSpace=wrap;html=1;fontSize=10;align=left;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;spacingLeft=6;verticalAlign=top;" value="Why wxO is not just a connector:&#xa;• Semantic routing — parses JSON, decides calls&#xa;• Conversational Q&amp;A — ad-hoc governance questions&#xa;• Cross-repo fan-out — one agent, many repos&#xa;• Fallback logic — detects OpenPages failure,&#xa;  re-routes to Graph API email&#xa;• Future: dedup, escalation, team routing" vertex="1">
          <mxGeometry height="110" width="240" x="40" y="1160" as="geometry" />
        </mxCell>
        <mxCell id="ann3" parent="1" style="whiteSpace=wrap;html=1;fontSize=10;align=left;fillColor=#e8f4e8;strokeColor=#107C10;fontColor=#107C10;spacingLeft=6;verticalAlign=top;" value="OpenPages owns email in prod:&#xa;• Audited in GRC audit log (CIP-010)&#xa;• Throttled (IMR bulletin scheduling)&#xa;• Retried on mail server failure&#xa;• Template owned by compliance team&#xa;• No extra credentials in wxO" vertex="1">
          <mxGeometry height="100" width="220" x="700" y="1160" as="geometry" />
        </mxCell>
        <mxCell id="ann4" parent="1" style="whiteSpace=wrap;html=1;fontSize=10;align=left;fillColor=#fff3cd;strokeColor=#f0a30a;spacingLeft=6;verticalAlign=top;" value="Migration path (when ready):&#xa;1. Configure OpenPages WF email template&#xa;2. Remove send_outlook_email from tools list&#xa;3. Remove OUTLOOK_* secrets&#xa;4. redeploy agent (deploy.sh)" vertex="1">
          <mxGeometry height="85" width="220" x="40" y="1280" as="geometry" />
        </mxCell>

      </root>
